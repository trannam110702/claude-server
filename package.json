{
  "name": "claude-server",
  "version": "1.0.0",
  "description": "Proxy server that forwards requests to Claude API",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n proxy,next -c blue,green \"npm run dev:proxy\" \"npm run dev:dashboard\"",
    "dev:proxy": "dotenv -e .env -- nodemon index.js",
    "dev:dashboard": "dotenv -e .env -- npm -w next-app run dev",
    "build": "npm -w next-app run build",
    "start": "concurrently -n proxy,next -c blue,green \"npm run start:proxy\" \"npm run start:dashboard\"",
    "start:proxy": "dotenv -e .env -- node index.js",
    "start:dashboard": "dotenv -e .env -- npm -w next-app start",
    "login": "node index.js login",
    "setup": "node index.js setup",
    "test:refresh": "node lib/test-refresh.js"
  },
  "private": true,
  "workspaces": [
    "next-app"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "better-sqlite3": "^11.0.0",
    "concurrently": "^9.0.0",
    "dotenv-cli": "^11.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
