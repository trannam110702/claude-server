# Server configuration
PORT=8080
HOST=127.0.0.1

# Authentication - use ONE of the following methods:

# Method 1: Direct API key
ANTHROPIC_API_KEY=sk-ant-...

# Method 2: OAuth tokens (from Claude subscription)
# OAUTH_ACCESS_TOKEN=...
# OAUTH_REFRESH_TOKEN=...
# OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e

# Claude API settings (defaults shown)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01

# Dashboard auth (NextAuth v5)
# Generate AUTH_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: override SQLite path (default: ./data/usage.db relative to repo root)
# DATABASE_PATH=/abs/path/to/usage.db
